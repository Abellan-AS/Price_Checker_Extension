{
  "manifest_version": 3,
  "name": "LiaCheck, Price Checker for Amazon, by AbellanLabs™",
  "version": "1.2",
  "permissions": ["activeTab"],
  "host_permissions": [
    "*://*.amazon.es/*",
    "*://*.amazon.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
"icons": {
  "16": "icon16.png",
  "48": "icon48.png",
  "128": "icon128.png"
},
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.es/*", 
        "*://*.amazon.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}